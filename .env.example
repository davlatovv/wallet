# ============================================================
# Telegram Bot
# ============================================================
BOT_TOKEN=your_bot_token_here

# ============================================================
# PostgreSQL
# ============================================================
POSTGRES_USER=wallet
POSTGRES_PASSWORD=wallet_secret
POSTGRES_DB=wallet_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Assembled by docker-compose / override locally
DATABASE_URL=postgresql+asyncpg://wallet:wallet_secret@postgres:5432/wallet_db

# ============================================================
# Application
# ============================================================
DEBUG=false
LOG_LEVEL=INFO
TIMEZONE=UTC

# Budget alert thresholds (0.0 – 1.0)
BUDGET_WARN_THRESHOLD=0.8
BUDGET_CRITICAL_THRESHOLD=1.0
